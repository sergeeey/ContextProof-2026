# CCBM Environment Configuration
# Copy this file to .env and fill in your values

# Core Settings
CCBM_ENV=production
CCBM_LOG_LEVEL=INFO

# Security
JWT_SECRET_KEY=your-secret-key-change-in-production
CCBM_REQUIRE_AUTH=true

# API Settings
API_HOST=0.0.0.0
API_PORT=8000

# Dashboard Settings
DASHBOARD_PORT=8501

# Redis (optional)
REDIS_URL=redis://localhost:6379

# LLM Settings (optional)
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434

# Telegram Notifications (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false

# Compliance
KZ_COMPLIANCE_ENABLED=true
DATA_LOCALIZATION_KZ=true
